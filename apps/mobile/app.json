{
  "expo": {
    "name": "AgroSolution",
    "slug": "agrosolution",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "agrosolution",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F5132"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrosolution.app"
    },
    "android": {
      "package": "com.agrosolution.app"
    }
  }
}
